# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
wheels/

# Virtual environments
.venv/
venv/
env/

# Test / lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ── Data artifacts ────────────────────────────────────────────────────────────
# Mounted as a volume at runtime (docker compose) or committed to HF Space repo.
# Never baked into the image — keeps layers lean and data/code concerns separate.
data/

# ── Frontend — only source needed; Stage 1 runs npm ci and builds fresh ──────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Docker files themselves ───────────────────────────────────────────────────
# No reason to copy these into the build context.
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.override.yml

# ── Documentation ─────────────────────────────────────────────────────────────
README.md
*.md

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/
